generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id               String          @id @default(uuid()) @db.Uuid
  role             Role            @default(USER)
  name             String
  email            String          @unique
  password         String
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  deletedAt        DateTime?       @db.Timestamptz(6)
  sentMessages     messages[]      @relation("sentMessages")
  orders           orders[]
  refreshTokens    refreshTokens[]
  wallet           wallets?
  rooms            rooms[]         @relation("roomsTousers")

  @@index([id])
  @@index([id, createdAt])
}

model products {
  id         String       @id @default(uuid()) @db.Uuid
  name       String
  price      Decimal      @db.Decimal(10, 2)
  stock      Int          @default(0)
  createdAt  DateTime     @default(now()) @db.Timestamptz(6)
  deletedAt  DateTime?    @db.Timestamptz(6)
  orderItems orderItems[]

  @@index([id])
  @@index([id, createdAt])
  @@index([name])
}

model orders {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String       @db.Uuid
  createdAt  DateTime     @default(now()) @db.Timestamptz(6)
  deletedAt  DateTime?    @db.Timestamptz(6)
  orderItems orderItems[]
  user       users        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([id])
  @@index([userId])
  @@index([id, createdAt])
  @@index([userId, createdAt])
}

model wallets {
  id           String               @id @default(uuid()) @db.Uuid
  userId       String               @unique @db.Uuid
  balance      Decimal              @default(0) @db.Decimal(10, 2)
  createdAt    DateTime             @default(now()) @db.Timestamptz(6)
  deletedAt    DateTime?            @db.Timestamptz(6)
  transactions walletTransactions[]
  user         users                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([id])
  @@index([userId])
  @@index([id, createdAt])
}

model walletTransactions {
  id        String   @id @default(uuid()) @db.Uuid
  walletId  String   @db.Uuid
  amount    Decimal
  type      txAction
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  wallet    wallets  @relation(fields: [walletId], references: [id])
}

model orderItems {
  id             String    @id @default(uuid()) @db.Uuid
  orderId        String    @db.Uuid
  productId      String    @db.Uuid
  quantity       Int
  purchasedPrice Decimal   @db.Decimal(10, 2)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  deletedAt      DateTime? @db.Timestamptz(6)
  order          orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        products  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([id, createdAt])
}

model refreshTokens {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  familyId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  used      Boolean  @default(false)
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
}

model auditLogs {
  id            String      @id @default(uuid()) @db.Uuid
  model         String
  modelId       String      @db.Uuid
  action        AuditAction
  oldData       Json?
  newData       Json?
  performedBy   String?     @db.Uuid
  performedRole Role?
  ipAddress     String?
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)

  @@index([model, modelId])
  @@index([performedBy])
  @@index([id, createdAt])
}

model messages {
  id        String    @id @default(uuid()) @db.Uuid
  from      String    @db.Uuid
  
  // ADD THE QUESTION MARK HERE
  to        String?   @db.Uuid 
  
  message   String
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)
  roomId    String?   @db.Uuid
  
  sender    users     @relation("sentMessages", fields: [from], references: [id])
  room      rooms?    @relation(fields: [roomId], references: [id])

  @@index([from])
  @@index([to])
  @@index([roomId]) // RECOMMENDED: Add an index for room lookups
  @@index([id, createdAt(sort: Desc)])
}

model rooms {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  messages  messages[]
  members   users[]    @relation("roomsTousers")
}

enum Role {
  ADMIN
  USER
}

enum txAction {
  DEBIT
  CREDIT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}
